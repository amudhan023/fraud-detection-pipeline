{
  "__inputs": [{ "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }],
  "title": "Real-Time Traffic",
  "uid": "fraud-traffic-001",
  "version": 1,
  "schemaVersion": 37,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "tags": ["fraud-pipeline"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Events / sec (all jobs)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":50000},{"color":"red","value":900000}] }, "unit": "ops" } },
      "targets": [{
        "expr": "sum(rate(flink_taskmanager_Status_JVM_CPU_Load[1m]))",
        "legendFormat": "events/s"
      }]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Throughput — Records In/Out Per Second",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (task_name) (rate(flink_taskmanager_job_task_operator_numRecordsIn[1m]))",
          "legendFormat": "in — {{task_name}}"
        },
        {
          "expr": "sum by (task_name) (rate(flink_taskmanager_job_task_operator_numRecordsOut[1m]))",
          "legendFormat": "out — {{task_name}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Kafka Consumer Lag",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "targets": [{
        "expr": "sum by (consumergroup) (kafka_consumergroup_lag{consumergroup=~\"flink-.*\"})",
        "legendFormat": "{{consumergroup}}"
      }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Checkpoint Duration (ms)",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "thresholdsStyle": { "mode": "line" } }, "thresholds": { "steps": [{"color":"green","value":null},{"color":"red","value":10000}] } } },
      "targets": [{
        "expr": "flink_jobmanager_job_lastCheckpointDuration",
        "legendFormat": "last checkpoint ms"
      }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "TaskManager Busy Ratio",
      "gridPos": { "x": 8, "y": 12, "w": 4, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":0.7},{"color":"red","value":0.9}] } } },
      "targets": [{
        "expr": "avg(flink_taskmanager_job_task_busyTimeMsPerSecond) / 1000",
        "legendFormat": "busy"
      }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Fraud Pipeline — Custom Counters",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "rate(flink_taskmanager_job_task_operator_fraud_pipeline_events_processed_total[1m])", "legendFormat": "processed/s" },
        { "expr": "rate(flink_taskmanager_job_task_operator_fraud_pipeline_late_events_dropped_total[5m])", "legendFormat": "late_dropped/s" },
        { "expr": "rate(flink_taskmanager_job_task_operator_fraud_pipeline_enrichment_misses_total[1m])", "legendFormat": "enrich_miss/s" }
      ]
    }
  ]
}
