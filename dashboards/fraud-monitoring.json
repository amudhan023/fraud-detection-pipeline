{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" },
    { "name": "DS_POSTGRES",   "label": "PostgreSQL",  "type": "datasource", "pluginId": "postgres" }
  ],
  "title": "Fraud Monitoring",
  "uid": "fraud-monitor-001",
  "version": 1,
  "schemaVersion": 37,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "tags": ["fraud-pipeline"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Anomalies Detected (last 5m)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":10},{"color":"red","value":50}] }, "unit": "short" } },
      "targets": [{
        "expr": "increase(flink_taskmanager_job_task_operator_fraud_pipeline_anomalies_detected_total[5m])",
        "legendFormat": "anomalies"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Fraud Rate (%)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":3},{"color":"red","value":10}] } } },
      "targets": [{
        "expr": "100 * rate(flink_taskmanager_job_task_operator_fraud_pipeline_anomalies_detected_total[5m]) / clamp_min(rate(flink_taskmanager_job_task_operator_fraud_pipeline_events_processed_total[5m]), 0.001)",
        "legendFormat": "fraud %"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Velocity Flags",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "orange", "mode": "fixed" } } },
      "targets": [{ "expr": "increase(flink_taskmanager_job_task_operator_fraud_pipeline_velocity_flags_total[5m])", "legendFormat": "velocity" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Amount Spike Flags",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "red", "mode": "fixed" } } },
      "targets": [{ "expr": "increase(flink_taskmanager_job_task_operator_fraud_pipeline_amount_spike_flags_total[5m])", "legendFormat": "spikes" }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Geo-Travel Flags",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "purple", "mode": "fixed" } } },
      "targets": [{ "expr": "increase(flink_taskmanager_job_task_operator_fraud_pipeline_geo_travel_flags_total[5m])", "legendFormat": "geo" }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Anomaly Rate Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "rate(flink_taskmanager_job_task_operator_fraud_pipeline_velocity_flags_total[1m])",     "legendFormat": "VELOCITY" },
        { "expr": "rate(flink_taskmanager_job_task_operator_fraud_pipeline_amount_spike_flags_total[1m])", "legendFormat": "AMOUNT_SPIKE" },
        { "expr": "rate(flink_taskmanager_job_task_operator_fraud_pipeline_geo_travel_flags_total[1m])",   "legendFormat": "GEO_TRAVEL" }
      ]
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "Anomaly Reason Breakdown",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        { "expr": "increase(flink_taskmanager_job_task_operator_fraud_pipeline_velocity_flags_total[30m])",     "legendFormat": "VELOCITY" },
        { "expr": "increase(flink_taskmanager_job_task_operator_fraud_pipeline_amount_spike_flags_total[30m])", "legendFormat": "AMOUNT_SPIKE" },
        { "expr": "increase(flink_taskmanager_job_task_operator_fraud_pipeline_geo_travel_flags_total[30m])",   "legendFormat": "GEO_TRAVEL" }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Recent Anomaly Events (live)",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 10 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "options": { "sortBy": [{ "displayName": "detected_at", "desc": true }] },
      "targets": [{
        "rawSql": "SELECT detected_at, transaction_id, account_id, reason_code, evidence FROM anomaly_events ORDER BY detected_at DESC LIMIT 50",
        "format": "table"
      }],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "reason_code" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "mappings", "value": [{"type":"value","options":{"VELOCITY":{"color":"orange","index":0},"AMOUNT_SPIKE":{"color":"red","index":1},"GEO_TRAVEL":{"color":"purple","index":2}}}] }] }
        ]
      }
    }
  ]
}
