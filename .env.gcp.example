# ── GCP Deployment Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in all values before running docker-compose.
#
# Usage:
#   cp .env.gcp.example .env
#   nano .env          # fill in YOUR values
#   docker compose -f infra/docker-compose.yml up -d

# ── Anthropic API (REQUIRED) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...your-key-here...

# ── PostgreSQL credentials ────────────────────────────────────────────────────
# Change these from the defaults for any non-local deployment.
POSTGRES_DB=frauddb
POSTGRES_USER=frauduser
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Flink checkpoint storage ──────────────────────────────────────────────────
# LOCAL  (single VM / local dev) — uses the docker volume, no extra setup:
#   FLINK_CHECKPOINT_DIR=file:///flink-checkpoints
#
# GCS    (recommended for GCP — survives container restarts):
#   FLINK_CHECKPOINT_DIR=gs://YOUR_GCS_BUCKET/flink-checkpoints
#
# Set your GCS bucket name below (created in Step 7 of the deployment guide).
FLINK_CHECKPOINT_DIR=gs://fraud-flink-ckpt-YOUR_PROJECT_ID/flink-checkpoints

# ── Google Cloud credentials for Flink → GCS access ─────────────────────────
# On GCE/GKE with a service account attached to the VM, leave blank — ADC works.
# On a machine WITHOUT a GCP service account (e.g. your laptop running against GCS):
#   1. Create a key: gcloud iam service-accounts keys create key.json --iam-account=...
#   2. Set the path below.
GOOGLE_APPLICATION_CREDENTIALS=

# ── Kafka external listener ───────────────────────────────────────────────────
# External clients (outside the docker network) use this address to reach Kafka.
# LOCAL dev   : localhost  (default, no change needed)
# GCP VM      : set to the VM's External IP  (gcloud compute instances describe ...)
# GKE         : set to the LoadBalancer IP of the kafka service
KAFKA_EXTERNAL_HOST=YOUR_GCP_VM_EXTERNAL_IP

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ── AI Agent / CORS ──────────────────────────────────────────────────────────
# Restrict to the actual UI host so browsers accept API responses.
# For a GCP VM deployment use:  http://YOUR_GCP_VM_EXTERNAL_IP:3001
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://YOUR_GCP_VM_EXTERNAL_IP:3001

# ── UI → AI Agent URL ────────────────────────────────────────────────────────
# The URL the Next.js server uses to proxy /api/* requests to the AI agent.
# Inside docker-compose this is always the internal service name.
API_URL=http://ai-agent:8000

# ── Load generator tuning ────────────────────────────────────────────────────
GENERATOR_RATE=100
GENERATOR_FRAUD_PCT=5

# ── Analysis interval ─────────────────────────────────────────────────────────
ANALYSIS_INTERVAL_SECONDS=30
